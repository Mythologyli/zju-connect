protocol = "easyconnect" # "easyconnect" or "anyconnect"
server_address = "rvpn.zju.edu.cn"
server_port = 443
username = "username"
password = "password"
disable_zju_config = false
disable_zju_dns = false
socks_bind = ":1080"
socks_user = ""
socks_passwd = ""
http_bind = ":1081"
shadowsocks_url = "" # "ss://aes-128-gcm:password@:1082"
dial_direct_proxy = "" # "http://127.0.0.1:7890" or "socks://127.0.0.1:7890"
tcp_tunnel_mode = false
tun_mode = false
add_route = false
dns_ttl = 3600
disable_keep_alive = false
zju_dns_server = "auto"
secondary_dns_server = "114.114.114.114"
dns_server_bind = ""
dns_hijack = false
debug_dump = false

# Port forwarding
port_forwarding = [
#    { network_type = "tcp", bind_address = "127.0.0.1:9898", remote_address = "10.10.98.98:80" },
#    { network_type = "tcp", bind_address = "127.0.0.1:9899", remote_address = "10.10.98.98:80" },
#    { network_type = "udp", bind_address = "127.0.0.1:1053", remote_address = "10.10.0.21:53" }
]

custom_dns = [
#    { host_name = "appservice.zju.edu.cn", ip = "10.203.8.198"},
#    { host_name = "www.cc98.org", ip = "10.10.98.98"}
]


# EasyConnect specific settings
totp_secret = ""
cert_file = ""
cert_password = ""
disable_server_config = false
skip_domain_resource = false
disable_multi_line = false
proxy_all = false
custom_proxy_domain = [
#    "science.org",
#    "nature.com"
]


# aTrust specific settings
auth_type = "auth/psw"
login_domain = "Radius"
client_data_file = "client_data.json"
graph_code_file = "graph_code.jpg"
cas_ticket = ""
phone = ""
update_best_nodes_interval = 300
sid = ""
device_id = ""
sign_key = ""
resource_file = ""